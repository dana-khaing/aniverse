NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-local-or-hosted-publishable-key
SUPABASE_SERVICE_ROLE_KEY=server-only-never-expose-to-the-browser
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Optional managed video. Local mode works without these values.
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=
MUX_SIGNING_KEY_ID=
# Preserve PEM line breaks or encode them as literal backslash-n sequences.
MUX_SIGNING_PRIVATE_KEY=

# Optional creator tipping. Viewing stays free; AniVerse takes no application fee.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional transactional email. Until a domain is verified, Resend restricts recipients.
RESEND_API_KEY=
RESEND_FROM_EMAIL=AniVerse <onboarding@resend.dev>

# Optional error monitoring and source-map upload.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
